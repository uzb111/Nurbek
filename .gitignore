# Python runtime files
__pycache__/
*.py[cod]

# Original and generated GIS data are intentionally not published.
# The GitHub repository is public; store these in a private data repository
# or approved object storage instead.
Smart_agriculture.gdb/
mvp_data_partial_*/
real_project_data/
_incoming_gdb_inspect_*/
mvp_data/Smart_agriculture_mvp.gdb/
mvp_data/geojson/*
mvp_data/*.json
mvp_data/*.csv
mvp_data/config/field_zone_review_*.csv

# Keep only the non-sensitive configuration and methodology needed to explain
# the pipeline.
!mvp_data/README.md
!mvp_data/DEMO_PROXY.md
!mvp_data/IRRIGATION_MVP.md
!mvp_data/config/
!mvp_data/config/irrigation_norms.csv
!mvp_data/config/crop_mapping.csv

# The deployable dashboard dataset. This is deliberately included because the
# public GitHub Pages site must display all field polygons without a local API.
!mvp_data/geojson/fields_demo_mvp.geojson
!mvp_data/geojson/kanal.geojson
!mvp_data/geojson/zovur.geojson
!mvp_data/geojson/fields_delivery_2025_lite.geojson
!mvp_data/geojson/fields_merged_manual.geojson
